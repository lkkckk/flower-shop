# PostgreSQL 数据库连接
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/flower_shop?schema=public"

# JWT 签名密钥（生产环境必须改为强随机 32+ 字符）
JWT_SECRET="dev-secret-change-me-min-32-chars-please-change"

# 微信小程序凭证（微信公众平台 → 开发管理 → 开发设置）
WECHAT_APPID=""
WECHAT_SECRET=""

# CORS 允许的源（生产环境建议指定域名，开发可用 *）
CORS_ORIGIN="*"
