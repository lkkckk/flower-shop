generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  sort      Int        @default(0)
  createdAt DateTime   @default(now())

  products  Product[]
}

model Product {
  id              Int       @id @default(autoincrement())
  name            String
  category        String?
  categoryId      Int?
  baseUnit        String
  grade           String?
  color           String?
  specification   String?
  defaultPrice    Float
  vipPrice        Float?
  wholesalePrice  Float?
  shelfLifeDays   Int      @default(7)
  attributes      String?   // JSON string, SQLite 不支持 Json 类型
  status          String   @default("active")
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categoryRef     Category?        @relation(fields: [categoryId], references: [id])
  unitConversions UnitConversion[]
  stockBatches    StockBatch[]
  orderItems      OrderItem[]
  recipe          ProductRecipe?   @relation("ProductRecipeProduct")
  recipeComponents ProductRecipeItem[] @relation("ProductRecipeComponent")
}

model UnitConversion {
  id          Int     @id @default(autoincrement())
  productId   Int
  fromUnit    String
  toBaseQty   Float
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, fromUnit])
}

model ProductRecipe {
  id        Int      @id @default(autoincrement())
  productId Int     @unique
  enabled   Boolean @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation("ProductRecipeProduct", fields: [productId], references: [id], onDelete: Cascade)
  items   ProductRecipeItem[]
}

model ProductRecipeItem {
  id                 Int     @id @default(autoincrement())
  recipeId           Int
  componentProductId Int
  qty                Float
  unit               String
  sort               Int     @default(0)
  notes              String?

  recipe           ProductRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  componentProduct Product       @relation("ProductRecipeComponent", fields: [componentProductId], references: [id])

  @@index([recipeId])
  @@index([componentProductId])
}

model StockBatch {
  id           Int      @id @default(autoincrement())
  productId    Int
  batchNo      String   @unique
  inboundDate  DateTime
  expiryDate   DateTime
  inboundQty   Float
  currentQty   Float
  costPrice    Float
  status       String   @default("in_stock")
  notes        String?
  createdAt    DateTime @default(now())

  product      Product         @relation(fields: [productId], references: [id])
  orderItems   OrderItem[]
  movements    StockMovement[]

  @@index([productId, status])
  @@index([expiryDate])
}

model StockMovement {
  id             Int      @id @default(autoincrement())
  batchId        Int
  type           String
  qtyChange      Float
  relatedOrderId Int?
  operator       String?
  notes          String?
  createdAt      DateTime @default(now())

  batch          StockBatch @relation(fields: [batchId], references: [id])

  @@index([createdAt])
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?  @unique
  address     String?
  level       String   @default("normal")
  balance     Float    @default(0)
  totalOwed   Float    @default(0)
  points      Int      @default(0)
  notes       String?
  // 微信小程序账号字段
  openid      String?  @unique
  unionid     String?
  nickname    String?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
  payments    Payment[]

  @@index([phone])
  @@index([openid])
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  name         String
  role         String   @default("staff") // staff | admin | cashier
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  processedOrders Order[] @relation("OrderCashier")
}

/// 全局单行配置（key-value）
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// 促销活动：满 X 减 Y
model Promotion {
  id         Int       @id @default(autoincrement())
  name       String
  type       String    @default("full_reduction") // full_reduction（预留阶梯/折扣）
  threshold  Float
  reduction  Float
  status     String    @default("active") // active | inactive
  startAt    DateTime?
  endAt      DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orders     Order[]
}

model Order {
  id              Int      @id @default(autoincrement())
  orderNo         String   @unique
  customerId      Int?
  orderType       String   @default("retail")
  totalAmount     Float
  paidAmount      Float    @default(0)
  owedAmount      Float    @default(0)
  paymentMethod   String?
  deliveryTime    DateTime?
  deliveryAddress String?
  notes           String?
  status          String   @default("pending")
  // 履约方式：delivery | pickup，供预售排单/备货看板使用
  fulfillmentType String   @default("delivery")
  // 是否已做好：轻量制作完成标记，不等同于完整订单状态流转
  isMade          Boolean  @default(false)
  // 是否加急/插单：用于排单优先展示
  isUrgent        Boolean  @default(false)
  // 手动排序预留字段
  sortIndex       Int      @default(0)
  // 价格模式：retail | vip | wholesale | discount | promotion
  priceMode       String?
  // 整单折扣率（0-100），仅 priceMode=discount 时使用
  discountRate    Float?
  promotionId     Int?
  // 预售单收货人信息（可能与下单客户不同）
  receiverName      String?
  receiverPhone     String?
  // 贺卡内容（鲜花预售常见，独立于 notes 以便单独打印）
  cardMessage       String?
  // 订单来源/渠道标记（如 "美团闪购#5"、"抖音#12"、"店内"），打印右上角显示
  sourceChannel     String?
  // 预售履约提醒阶段：none | d7 | d3 | due | overdue
  reminderStage     String?   @default("none")
  reminderUpdatedAt DateTime?
  // 结账收银员
  cashierId         Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer        Customer?   @relation(fields: [customerId], references: [id])
  promotion       Promotion?  @relation(fields: [promotionId], references: [id])
  cashier         User?       @relation("OrderCashier", fields: [cashierId], references: [id])
  items           OrderItem[]
  payments        Payment[]

  @@index([createdAt])
  @@index([customerId])
  @@index([orderType, deliveryTime])
  @@index([orderType, deliveryTime, isMade])
  @@index([orderType, status])
}

model OrderItem {
  id            Int     @id @default(autoincrement())
  orderId       Int
  productId     Int
  // 预售单创建时不绑定批次，批次在转执行阶段按 FIFO 分配
  batchId       Int?
  unit          String
  qty           Float
  baseQty       Float
  unitPrice     Float
  /// 成交价所基于的基础价（priceMode 应用前的参考价，用于审计）
  originalPrice Float?
  subtotal      Float
  grade         String?
  color         String?
  notes         String?
  // 预售下单时保存的商品参考图（下单瞬间的商品图片快照，用于配送单打印）
  imageUrl      String?

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
  batch       StockBatch? @relation(fields: [batchId], references: [id])
}

model Payment {
  id              Int      @id @default(autoincrement())
  customerId      Int?
  orderId         Int?
  amount          Float
  paymentMethod   String
  type            String
  operator        String?
  notes           String?
  createdAt       DateTime @default(now())

  customer        Customer? @relation(fields: [customerId], references: [id])
  order           Order?    @relation(fields: [orderId], references: [id])

  @@index([customerId, createdAt])
}
